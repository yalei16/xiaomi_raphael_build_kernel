+static bool tfa987x_cnt_skip_reg(u8 addr)
+{
+	/* Never let cnt override power/TDM routing */
+	if (addr <= 0x05 || (addr >= 0x20 && addr <= 0x27))
+		return true;
+	return false;
+}
+
+static int tfa987x_init_tdm(struct regmap *rmap)
+{
+	int ret;
+
+	/*
+	 * Match Qualcomm Quaternary TDM: 8 slots, 32-bit slot width on the
+	 * bus, 16-bit PCM in the lower bits. Speaker data on TDM slot 0.
+	 */
+	ret = regmap_update_bits(rmap, TFA987X_TDM_CFG0,
+				 TFA987X_TDM_CFG0_FSBCLKS_MSK,
+				 FIELD_PREP(TFA987X_TDM_CFG0_FSBCLKS_MSK, 0));
+	if (ret)
+		return ret;
+
+	ret = regmap_update_bits(rmap, TFA987X_TDM_CFG1,
+				 TFA987X_TDM_CFG1_NSLOTS_MSK |
+				 TFA987X_TDM_CFG1_SLOTBITS_MSK,
+				 FIELD_PREP(TFA987X_TDM_CFG1_NSLOTS_MSK, 8) |
+				 FIELD_PREP(TFA987X_TDM_CFG1_SLOTBITS_MSK, 31));
+	if (ret)
+		return ret;
+
+	ret = regmap_update_bits(rmap, TFA987X_TDM_CFG2,
+				 TFA987X_TDM_CFG2_SWIDTH_MSK,
+				 FIELD_PREP(TFA987X_TDM_CFG2_SWIDTH_MSK, 15));
+	if (ret)
+		return ret;
+
+	ret = regmap_update_bits(rmap, TFA987X_TDM_CFG3,
+				 TFA987X_TDM_CFG3_SPKE_MSK |
+				 TFA987X_TDM_CFG3_DCE_MSK |
+				 TFA987X_TDM_CFG3_CSE_MSK |
+				 TFA987X_TDM_CFG3_VSE_MSK,
+				 TFA987X_TDM_CFG3_SPKE_MSK);
+	if (ret)
+		return ret;
+
+	ret = regmap_update_bits(rmap, TFA987X_TDM_CFG6,
+				 TFA987X_TDM_CFG6_SPKS_MSK,
+				 FIELD_PREP(TFA987X_TDM_CFG6_SPKS_MSK, 0));
+	if (ret)
+		return ret;
+
+	return regmap_update_bits(rmap, TFA987X_SYS_CTRL2,
+				  TFA987X_SYS_CTRL2_AUDFS_MSK,
+				  FIELD_PREP(TFA987X_SYS_CTRL2_AUDFS_MSK, 1));
+}
+
+static int tfa987x_apply_cnt_patch(struct regmap *rmap,
+				   const struct tfa987x_cnt_patch *patch)
+{
+	unsigned int old, new;
+	int ret;
+
+	ret = regmap_read(rmap, patch->addr, &old);
+	if (ret)
+		return ret;
+
+	new = (old & ~patch->mask) | (patch->value & patch->mask);
+	return regmap_write(rmap, patch->addr, new);
+}
+
+static int tfa987x_apply_cnt_patches(struct regmap *rmap,
+				     const struct tfa987x_cnt_patch *patches,
+				     size_t count)
+{
+	size_t i;
+	int ret;
+
+	for (i = 0; i < count; i++) {
+		if (tfa987x_cnt_skip_reg(patches[i].addr))
+			continue;
+		ret = tfa987x_apply_cnt_patch(rmap, &patches[i]);
+		if (ret)
+			return ret;
+	}
+
+	return 0;
+}
+
+static int tfa987x_cnt_verify(const struct firmware *fw)
+{
+	const u8 *data = fw->data;
+	u32 crc, expected;
+
+	if (fw->size < 44)
+		return -EINVAL;
+
+	if (get_unaligned_le16(data) != TFA987X_CNT_MAGIC)
+		return -EINVAL;
+
+	expected = get_unaligned_le32(data + 10);
+	crc = crc32_le(~0, data + TFA987X_CNT_HDR_SIZE,
+		       fw->size - TFA987X_CNT_HDR_SIZE);
+	if (crc != expected) {
+		/* tfa98xx.cnt stores the raw crc32_le result */
+		if (~crc != expected)
+			return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int tfa987x_cnt_find(const u8 *data, size_t size,
+			    const u8 *pattern, size_t pattern_len,
+			    size_t *offset)
+{
+	size_t i;
+
+	if (pattern_len > size)
+		return -ENOENT;
+
+	for (i = 0; i <= size - pattern_len; i++) {
+		if (!memcmp(data + i, pattern, pattern_len)) {
+			*offset = i;
+			return 0;
+		}
+	}
+
+	return -ENOENT;
+}
+
+static int tfa987x_cnt_apply_block(struct regmap *rmap, struct device *dev,
+				   const u8 *data, size_t size)
+{
+	size_t i = 0;
+
+	while (i + 3 < size) {
+		u8 addr = data[i];
+		u16 value = get_unaligned_le16(data + i + 1);
+		u16 mask = data[i + 3];
+		struct tfa987x_cnt_patch patch;
+		int ret;
+
+		if (!memcmp(data + i, "PA1", 3))
+			break;
+
+		if (value == 0 && mask > 0 && mask <= 50) {
+			usleep_range(mask * 1000, mask * 1000 + 500);
+			i += 4;
+			continue;
+		}
+
+		if (addr > 0x90 || (mask == 0 && value == 0))
+			break;
+
+		if (tfa987x_cnt_skip_reg(addr)) {
+			i += 4;
+			continue;
+		}
+
+		patch.addr = addr;
+		patch.value = value;
+		patch.mask = mask;
+		ret = tfa987x_apply_cnt_patch(rmap, &patch);
+		if (ret)
+			return ret;
+
+		i += 4;
+	}
+
+	return 0;
+}
+
+static int tfa987x_load_cnt(struct regmap *rmap, struct device *dev)
+{
+	static const u8 dev_mark[] = { 0x08, 0x01, 0x00, 0x02 };
+	static const u8 prof_mark[] = { 0x01, 0x00, 0x03, 0x21, 0x01, 0x00, 0x30 };
+	const struct firmware *fw;
+	size_t dev_off, prof_off;
+	int ret;
+
+	ret = request_firmware(&fw, TFA987X_CNT_FW_NAME, dev);
+	if (ret) {
+		dev_warn(dev, "cnt %s not found (%d), using embedded profile\n",
+			 TFA987X_CNT_FW_NAME, ret);
+		return tfa987x_apply_cnt_patches(rmap,
+				tfa987x_cnt_profile_fallback,
+				ARRAY_SIZE(tfa987x_cnt_profile_fallback));
+	}
+
+	ret = tfa987x_cnt_verify(fw);
+	if (ret) {
+		dev_warn(dev, "cnt checksum invalid, using embedded profile\n");
+		release_firmware(fw);
+		return tfa987x_apply_cnt_patches(rmap,
+				tfa987x_cnt_profile_fallback,
+				ARRAY_SIZE(tfa987x_cnt_profile_fallback));
+	}
+
+	ret = tfa987x_cnt_find(fw->data, fw->size, dev_mark, sizeof(dev_mark),
+			       &dev_off);
+	if (!ret) {
+		ret = tfa987x_cnt_apply_block(rmap, dev, fw->data + dev_off,
+					      fw->size - dev_off);
+		if (ret)
+			dev_warn(dev, "cnt device block failed: %d\n", ret);
+	}
+
+	ret = tfa987x_cnt_find(fw->data, fw->size, prof_mark, sizeof(prof_mark),
+			       &prof_off);
+	if (!ret) {
+		prof_off += 3;
+		ret = tfa987x_cnt_apply_block(rmap, dev, fw->data + prof_off,
+					      fw->size - prof_off);
+		if (ret) {
+			dev_warn(dev, "cnt profile block failed: %d\n", ret);
+			ret = tfa987x_apply_cnt_patches(rmap,
+					tfa987x_cnt_profile_fallback,
+					ARRAY_SIZE(tfa987x_cnt_profile_fallback));
+		}
+	} else {
+		dev_warn(dev, "cnt profile block missing, using embedded profile\n");
+		ret = tfa987x_apply_cnt_patches(rmap,
+				tfa987x_cnt_profile_fallback,
+				ARRAY_SIZE(tfa987x_cnt_profile_fallback));
+	}
+
+	release_firmware(fw);
+	return ret;
+}
