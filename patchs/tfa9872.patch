+static void tfa987x_power(struct snd_soc_component *component, bool on)
+{
+	unsigned int reg;
+
+	if (on) {
+		snd_soc_component_update_bits(component, TFA987X_SYS_CTRL0,
+					      TFA987X_SYS_CTRL0_PWDN_MSK |
+					      TFA987X_SYS_CTRL0_DCDC_MSK |
+					      TFA987X_SYS_CTRL0_AMPE_MSK,
+					      TFA987X_SYS_CTRL0_DCDC_MSK |
+					      TFA987X_SYS_CTRL0_AMPE_MSK);
+		reg = snd_soc_component_read(component, TFA987X_SYS_CTRL0);
+		dev_info(component->dev, "amp power ON: REG00=0x%04x\n", reg);
+	} else {
+		snd_soc_component_update_bits(component, TFA987X_SYS_CTRL0,
+					      TFA987X_SYS_CTRL0_AMPE_MSK, 0);
+	}
+}
