+static unsigned int q6asm_dai_get_rate(struct snd_soc_pcm_runtime *fe,
+				       struct snd_pcm_substream *substream)
+{
+	struct snd_soc_dpcm *dpcm;
+	unsigned int rate = substream->runtime->rate;
+
+	for_each_dpcm_be(fe, substream->stream, dpcm) {
+		struct snd_pcm_hw_params *be_params;
+
+		if (!dpcm->be)
+			continue;
+
+		be_params = &dpcm->be->dpcm[substream->stream].hw_params;
+		if (params_rate(be_params)) {
+			rate = params_rate(be_params);
+			break;
+		}
+	}
+
+	return rate;
+}
