+&remoteproc_slpi {
+	status = "okay";
+	firmware-name = "qcom/sm8150/Xiaomi/raphael/slpi.mbn";
+	required-opps = <&rpmhpd_opp_turbo>;
+};
+
+&remoteproc_adsp {
+	status = "okay";
+	firmware-name = "qcom/sm8150/Xiaomi/raphael/adsp.mbn";
+	required-opps = <&rpmhpd_opp_turbo>;
+};
+
+&remoteproc_cdsp {
+	status = "okay";
+	firmware-name = "qcom/sm8150/Xiaomi/raphael/cdsp.mbn";
+	required-opps = <&rpmhpd_opp_turbo>;
+};
+
+&remoteproc_mpss {
+	status = "okay";
+	firmware-name = "qcom/sm8150/Xiaomi/raphael/modem.mbn";
+    qcom,mba-firmware-name = "qcom/sm8150/Xiaomi/raphael/mba.mbn"; 
+    mboxes = <&apss_shared 12>;
+    qcom,smem-states = <&modem_smp2p_out 0>;
+    qcom,smem-state-names = "stop";
+    // 以下属性启用 MHI 功能（如果内核驱动支持）
+    qcom,use-pil;
+    qcom,is-loadable;
+	required-opps = <&rpmhpd_opp_turbo>;
+};
+
+&q6asmdai{
+	dai@0 {
+		compatible = "qcom,q6afe-dai";
+		reg = <0>;
+		direction = <2>;
+
+	};
+};
+
+&i2c1 {
+    status = "okay";
+    clock-frequency = <400000>;
+    pinctrl-names = "default";
+    pinctrl-0 = <&qup_i2c1_default>;
+
+    tfa9874: audio-codec@34 {
+        compatible = "nxp,tfa9874";
+        reg = <0x34>; 
+        #sound-dai-cells = <0>;
+        
+        vddd-supply = <&vreg_l7a_1p8>;   
+        vdda-supply = <&vreg_l10c_3p3>; 
+        reset-gpios = <&tlmm 59 GPIO_ACTIVE_HIGH>;
+        
+        firmware-name = "tfa9874.cnt";
+        status = "okay";
+    };
+ };
+
+ &sound {
+    compatible = "qcom,sm8150-sndcard";
+    model = "xiaomi-raphael";
+    audio-routing = "Speaker", "OUT";
+
+    /* 定义 DAI (Digital Audio Interface) 链路 */
+    dai-link@0 {
+        reg = <0>;
+        link-name = "Primary MI2S";
+        cpu {
+            sound-dai = <&q6asmdai 0>;
+        };
+        platform {
+            sound-dai = <&q6asmdai 0>;
+        };
+        codec {
+            sound-dai = <&tfa9874>;
+        };
+    };
+};
